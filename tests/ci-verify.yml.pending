name: headline-gates
on:
  push:
    branches: [main]
  workflow_dispatch:
jobs:
  verify:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with: { python-version: "3.11" }
      - run: pip install pandas
      - name: 논문 헤드라인 수치 게이트 (11건)
        run: python tests/verify_headline_numbers.py
